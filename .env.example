# Optional. The app works without this key by using the deterministic fallback parser.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Supabase/PostgreSQL runtime. Set LOGISTICS_DATA_SOURCE=supabase in deployed
# environments, or leave unset locally to fall back to data/logistics.csv.
LOGISTICS_DATA_SOURCE=
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Import-only secret for `npm run db:import`. Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Replace after deploying.
NEXT_PUBLIC_DEPLOYMENT_URL=https://ai-analytics-dashboard-puce.vercel.app
